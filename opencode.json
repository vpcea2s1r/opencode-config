{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "apiKey": "",
      "options": {
        "setCacheKey": true
      },
      "models": {
        "big-pickle": { "name": "Big Pickle", "temperature": true },
        "gpt-5-nano": { "name": "GPT-5 Nano", "temperature": true },
        "minimax-m2.5-free": { "name": "MiniMax M2.5 Free", "temperature": true },
        "nemotron-3-super-free": { "name": "Nemotron 3 Super Free", "temperature": true }
      }
    }
  },
  "model": "opencode/big-pickle",
  "agent": {
    "architect": {
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "description": "High-level architecture and design"
    },
    "build": {
      "model": "opencode/gpt-5-nano",
      "temperature": 0.2,
      "description": "Implementation and coding",
      "maxSteps": 50
    },
    "plan": {
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "description": "Planning and analysis"
    },
    "tester": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.3,
      "description": "Testing and validation"
    }
  },
  "modes": {
    "precise": { "model": "opencode/big-pickle", "temperature": 0.1 },
    "balanced": { "model": "opencode/minimax-m2.5-free", "temperature": 0.4 },
    "fast": { "model": "opencode/gpt-5-nano", "temperature": 0.2 }
  }
}